{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PPT Content Inventory",
  "type": "object",
  "required": ["content_inventory", "edit_instruction_inventory", "uncertain_content_inventory"],
  "properties": {
    "content_inventory": {
      "type": "array",
      "description": "正式内容账本。所有需要进入最终页面的原始信息。",
      "items": {
        "type": "object",
        "required": ["id", "page", "type", "value", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^source-[0-9]{3,}$" },
          "page": { "type": "integer", "minimum": 1 },
          "type": {
            "type": "string",
            "enum": [
              "title",
              "subtitle",
              "body",
              "metric",
              "label",
              "chart",
              "relation",
              "flow_node",
              "note",
              "image_caption"
            ]
          },
          "value": { "type": "string" },
          "unit": { "type": "string" },
          "trend": { "type": "string" },
          "parentId": { "type": "string" },
          "relation": { "type": "string" },
          "status": { "type": "string", "const": "official" }
        },
        "additionalProperties": true
      }
    },
    "edit_instruction_inventory": {
      "type": "array",
      "description": "编辑备注和待修改占位符，不进入最终正文。",
      "items": {
        "type": "object",
        "required": ["id", "page", "value", "reason", "action"],
        "properties": {
          "id": { "type": "string", "pattern": "^edit-[0-9]{3,}$" },
          "page": { "type": "integer", "minimum": 1 },
          "value": { "type": "string" },
          "reason": { "type": "string" },
          "action": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "uncertain_content_inventory": {
      "type": "array",
      "description": "不确定是正式内容还是编辑备注的内容，需要人工确认。",
      "items": {
        "type": "object",
        "required": ["id", "page", "value", "reason", "action"],
        "properties": {
          "id": { "type": "string", "pattern": "^uncertain-[0-9]{3,}$" },
          "page": { "type": "integer", "minimum": 1 },
          "value": { "type": "string" },
          "reason": { "type": "string" },
          "action": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
