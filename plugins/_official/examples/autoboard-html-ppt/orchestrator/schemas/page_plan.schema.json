{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PPT Orchestrator V2 Page Plan",
  "$comment": "V2.7.0 — additionalProperties:false on slide items; sourcePageRefs conditional on provenanceType; source ID pattern extended",
  "type": "object",
  "required": [
    "slides"
  ],
  "properties": {
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "outputSlideIndex",
          "provenanceType",
          "pageRole",
          "pageType",
          "layoutComponent",
          "variant",
          "routingEvidence",
          "contentRefs",
          "contentMapping",
          "splitDecision",
          "styleSkill",
          "backgroundVariant",
          "structureFrozen"
        ],
        "properties": {
          "outputSlideIndex": {
            "type": "integer",
            "minimum": 1
          },
          "provenanceType": {
            "type": "string",
            "enum": ["source_document", "user_prompt"],
            "description": "source_document=优化已有PPT（sourcePageRefs必填）；user_prompt=新建任务（promptContentRefs必填，sourcePageRefs可为空）"
          },
          "sourcePageRefs": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            },
            "description": "provenanceType=source_document时minItems=1；user_prompt时允许为空数组"
          },
          "promptContentRefs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "provenanceType=user_prompt时必填；source_document时可省略"
          },
          "pageRole": {
            "type": "string",
            "enum": [
              "cover",
              "section",
              "content",
              "closing"
            ]
          },
          "pageType": {
            "type": "string",
            "enum": [
              "CoverPage",
              "SectionDividerPage",
              "ClosingPage",
              "AgendaPage",
              "MetricOverviewPage",
              "MultiColumnComparisonPage",
              "EcosystemRelationshipPage",
              "StrategyPanoramaPage",
              "StageEvolutionPage",
              "DualCoreArchitecturePage",
              "FormulaDecompositionPage",
              "CaseStudyPage",
              "ProcessFlowPage",
              "CentralModelPage",
              "ShowcaseGalleryPage",
              "TransformationPage",
              "CapabilityRoadmapPage",
              "CapabilityMatrixPage",
              "ChartAnalysisPage",
              "StructuredContentPage"
            ]
          },
          "layoutComponent": {
            "type": "string"
          },
          "templateId": {
            "type": "string",
            "enum": [
              "cover-centered-hero",
              "agenda-chapter-columns",
              "metric-story-triple",
              "metrics-taxonomy-matrix",
              "ecosystem-bridge",
              "strategy-before-after",
              "capability-engine-architecture",
              "case-problem-solution-impact",
              "case-journey-growth",
              "screenshot-flow-kpi",
              "maturity-stage-triple",
              "radial-capability-map",
              "media-gallery-edge-metrics",
              "dual-wing-comparison",
              "dual-track-evidence-kpi",
              "parallel-stage-flow",
              "capability-evolution-roadmap",
              "opportunity-portfolio",
              "capability-pillar-matrix",
              "closing-call-to-action",
              "growth-flywheel-loop",
              "capability-upgrade-ladder",
              "before-after-effect-compare",
              "funnel-conversion-story",
              "decision-priority-map"
            ]
          },
          "preservationMode": {
            "type": "string",
            "enum": ["verbatim", "display_optimize", "summarize"],
            "description": "verbatim=默认严格保真；display_optimize=展示优化；summarize=总结精简（需用户明确指令）"
          },
          "slideStatus": {
            "type": "string",
            "enum": ["planned", "rendered", "pending_runtime_audit", "pass", "failed_recoverable", "blocked"],
            "description": "单页渲染状态，独立于整体 Artifact 状态"
          },
          "failureReason": {
            "type": "string",
            "description": "slideStatus=blocked时必填"
          },
          "templateSelection": {
            "type": "object",
            "required": [
              "canvasVariant",
              "adaptationActions"
            ],
            "properties": {
              "primaryPatternMatch": {
                "type": "array",
                "items": { "type": "string" }
              },
              "slotCoverage": {
                "type": "array",
                "items": { "type": "string" }
              },
              "canvasVariant": {
                "type": "string",
                "enum": ["wideVariant", "ultrawideVariant"]
              },
              "adaptationActions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "rejectedTemplates": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "alignmentContract": {
            "type": "object",
            "required": [
              "contentBandId",
              "heightMode",
              "moduleAlignment",
              "geometryCheck",
              "maxErrorPx"
            ],
            "properties": {
              "contentBandId": { "type": "string" },
              "heightMode": {
                "type": "string",
                "enum": ["shared-content-band", "independent-module"]
              },
              "moduleAlignment": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["top", "bottom", "equal-height"]
                },
                "minItems": 1
              },
              "geometryCheck": {
                "type": "string",
                "const": "getBoundingClientRect"
              },
              "maxErrorPx": {
                "type": "number",
                "minimum": 0,
                "maximum": 2
              }
            },
            "additionalProperties": false
          },
          "variant": {
            "type": "string"
          },
          "routingEvidence": {
            "type": "object",
            "required": ["positive", "negative", "rejectedTypes", "confidence"],
            "properties": {
              "positive": {
                "type": "array",
                "items": { "type": "string" }
              },
              "negative": {
                "type": "array",
                "items": { "type": "string" }
              },
              "rejectedTypes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "additionalProperties": false
          },
          "contentRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(source-(text|media|chart|table|ocr)-[0-9]{3,}(-fragment-[0-9]{2,})?|derived-display-[0-9]{3,}|generated-visual-[0-9]{3,}|source-[0-9]{3,})$",
              "$comment": "支持 source-text-001、source-media-001、source-001(旧格式兼容)、derived-display-001 等"
            }
          },
          "contentMapping": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["region", "contentRefs"],
              "properties": {
                "region": { "type": "string" },
                "contentRefs": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^(source-(text|media|chart|table|ocr)-[0-9]{3,}(-fragment-[0-9]{2,})?|derived-display-[0-9]{3,}|generated-visual-[0-9]{3,}|source-[0-9]{3,})$"
                  }
                },
                "intentionalDuplicate": { "type": "boolean" },
                "duplicateRole": {
                  "type": "string",
                  "enum": ["continuation_context", "legend", "annotation", "navigation_context", "comparison_reference"],
                  "description": "intentionalDuplicate=true时必填，说明重复的业务理由"
                }
              },
              "additionalProperties": false
            }
          },
          "requiredCapabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "advancedRelationSpec": {
            "type": "object",
            "required": [
              "relationType",
              "sourceRefs",
              "requiredFacts",
              "geometryAnchors",
              "rejectedAlternatives",
              "auditChecks"
            ],
            "properties": {
              "relationType": {
                "type": "string",
                "enum": [
                  "feedbackLoop",
                  "capabilityProgression",
                  "beforeAfter",
                  "funnelConversion",
                  "decisionBranch",
                  "priorityAxes",
                  "kpiDecomposition",
                  "waterfallArithmetic"
                ]
              },
              "sourceRefs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^(source-(text|media|chart|table|ocr)-[0-9]{3,}(-fragment-[0-9]{2,})?|source-[0-9]{3,})$"
                }
              },
              "requiredFacts": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "geometryAnchors": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "rejectedAlternatives": {
                "type": "array",
                "items": { "type": "string" }
              },
              "auditChecks": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "splitDecision": {
            "type": "object",
            "required": ["needSplit", "reason"],
            "properties": {
              "needSplit": { "type": "boolean" },
              "reason": { "type": "string" },
              "splitGroupId": { "type": "string" }
            },
            "additionalProperties": false
          },
          "styleSkill": {
            "type": "string"
          },
          "backgroundVariant": {
            "type": "string",
            "enum": ["cover", "content", "closing"]
          },
          "showLogo": {
            "type": "boolean"
          },
          "logoVariant": {
            "type": "string"
          },
          "titleAlign": {
            "type": "string",
            "enum": ["center", "left"],
            "description": "默认center；特殊布局（DualWingPage/StrategyPanoramaPage等）可声明left，须在routingEvidence中注明理由"
          },
          "structureFrozen": {
            "type": "boolean",
            "const": true
          },
          "extensions": {
            "type": "object",
            "description": "用于扩展字段，避免破坏 additionalProperties:false 约束"
          }
        },
        "additionalProperties": false,
        "if": {
          "properties": {
            "provenanceType": { "const": "source_document" }
          }
        },
        "then": {
          "properties": {
            "sourcePageRefs": { "minItems": 1 }
          }
        },
        "else": {
          "required": ["promptContentRefs"],
          "properties": {
            "promptContentRefs": { "minItems": 1 }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
